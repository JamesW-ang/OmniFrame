<UserControl x:Class="OmniFrame.Wpf.Views.PluginManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
        <!-- 左：插件列表 -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="8" Margin="0,0,4,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="插件列表" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding Plugins}" SelectedItem="{Binding SelectedPlugin}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}">
                    <ListBox.ItemTemplate><DataTemplate><StackPanel><TextBlock Text="{Binding Name}" FontSize="13"/><TextBlock Text="{Binding Version, StringFormat=v{0}}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="加载" Width="60" Background="{StaticResource RunBrush}" Command="{Binding LoadCommand}" Margin="0,0,4,0"/>
                    <Button Content="卸载" Width="60" Background="{StaticResource ErrorBrush}" Command="{Binding UnloadCommand}" Margin="0,0,4,0"/>
                    <Button Content="刷新" Width="60" Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- 右：详情+测试 -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 详情 -->
                    <TextBlock Text="插件详情" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="名称:" Width="60" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock Text="{Binding DetailName}" Foreground="{StaticResource TextBrush}"/></StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="类型:" Width="60" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock Text="{Binding DetailType}" Foreground="{StaticResource TextBrush}"/></StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="版本:" Width="60" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock Text="{Binding DetailVersion}" Foreground="{StaticResource TextBrush}"/></StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,12"><TextBlock Text="状态:" Width="60" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock Text="{Binding DetailStatus}" Foreground="{StaticResource AccentBrush}"/></StackPanel>
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                    <!-- 运动测试 -->
                    <TextBlock Text="运动控制测试" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="轴:" Foreground="{StaticResource TextSecondaryBrush}" Width="30" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MotionTestAxis}" Width="50" Margin="0,0,8,0"/>
                        <TextBlock Text="位置:" Foreground="{StaticResource TextSecondaryBrush}" Width="40" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MotionTestPos}" Width="60" Margin="0,0,8,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="连接" Width="60" FontSize="11" Command="{Binding MotionConnectCmd}" Margin="0,0,4,0"/>
                        <Button Content="移动" Width="60" FontSize="11" Background="{StaticResource RunBrush}" Command="{Binding MotionMoveCmd}" Margin="0,0,4,0"/>
                        <Button Content="回零" Width="60" FontSize="11" Background="{StaticResource WarnBrush}" Command="{Binding MotionHomeCmd}"/>
                    </StackPanel>
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                    <!-- PLC 测试 -->
                    <TextBlock Text="PLC 测试" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="地址:" Foreground="{StaticResource TextSecondaryBrush}" Width="40" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding PlcTestAddr}" Width="80" Margin="0,0,8,0"/>
                        <TextBlock Text="值:" Foreground="{StaticResource TextSecondaryBrush}" Width="30" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding PlcTestValue}" Width="80"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="连接" Width="60" FontSize="11" Command="{Binding PlcConnectCmd}" Margin="0,0,4,0"/>
                        <Button Content="读取" Width="60" FontSize="11" Background="{StaticResource AccentBrush}" Command="{Binding PlcReadCmd}" Margin="0,0,4,0"/>
                        <Button Content="写入" Width="60" FontSize="11" Background="{StaticResource RunBrush}" Command="{Binding PlcWriteCmd}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
