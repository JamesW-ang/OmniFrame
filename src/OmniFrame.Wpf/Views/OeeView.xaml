<UserControl x:Class="OmniFrame.Wpf.Views.OeeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Content="刷新 OEE" Command="{Binding RefreshCommand}" Width="100" Margin="0,0,0,16"/>
        <UniformGrid Grid.Row="1" Columns="2" Rows="2">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="8" Padding="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="可用性" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <TextBlock Text="{Binding Availability, StringFormat={}{0:F1}%}" Foreground="{StaticResource AccentBrush}" FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="8" Padding="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="表现性" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <TextBlock Text="{Binding Performance, StringFormat={}{0:F1}%}" Foreground="{StaticResource RunBrush}" FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="8" Padding="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="质量" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <TextBlock Text="{Binding Quality, StringFormat={}{0:F1}%}" Foreground="{StaticResource WarnBrush}" FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="8" Padding="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="OEE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <TextBlock Text="{Binding Oee, StringFormat={}{0:F1}%}" Foreground="{StaticResource AccentBrush}" FontSize="48" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
