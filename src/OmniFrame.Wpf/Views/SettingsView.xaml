<UserControl x:Class="OmniFrame.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl SelectedIndex="{Binding SelectedTab}" Background="{StaticResource BackgroundBrush}" Margin="12">
        <TabControl.Resources>
            <Style TargetType="TabItem"><Setter Property="Background" Value="{StaticResource SurfaceBrush}"/><Setter Property="Foreground" Value="{StaticResource TextBrush}"/><Setter Property="FontSize" Value="13"/><Setter Property="Padding" Value="16,8"/></Style>
            <Style TargetType="DataGrid"><Setter Property="Background" Value="{StaticResource SurfaceBrush}"/><Setter Property="Foreground" Value="{StaticResource TextBrush}"/><Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/><Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/><Setter Property="AutoGenerateColumns" Value="True"/></Style>
        </TabControl.Resources>

        <!-- 系统参数 -->
        <TabItem Header="系统参数"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><TextBlock Text="工作模式:" Width="120" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/><TextBox Text="{Binding SysWorkMode}" Width="120"/></StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"><TextBlock Text="看门狗间隔(ms):" Width="120" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/><TextBox Text="{Binding SysWatchdogInterval}" Width="120"/></StackPanel>
            <CheckBox Grid.Row="2" Content="自动重连" IsChecked="{Binding SysAutoReconnect}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
            <StackPanel Grid.Row="3" Orientation="Horizontal"><TextBlock Text="健康检查端口:" Width="120" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/><TextBox Text="{Binding SysHealthPort}" Width="120"/></StackPanel>
        </Grid></TabItem>

        <!-- 运动控制 -->
        <TabItem Header="运动控制"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <TextBlock Text="运动卡列表" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding MotionCards}"/>
            <TextBlock Grid.Row="2" Text="轴参数" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
            <DataGrid Grid.Row="3" ItemsSource="{Binding AxisParams}"/>
        </Grid></TabItem>

        <!-- PLC -->
        <TabItem Header="PLC 配置"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <TextBlock Text="PLC 列表" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding PlcConfigs}"/>
            <TextBlock Grid.Row="2" Text="寄存器映射" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
            <DataGrid Grid.Row="3" ItemsSource="{Binding RegisterMaps}"/>
        </Grid></TabItem>

        <!-- IO -->
        <TabItem Header="IO 配置"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <TextBlock Text="输入点" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock Grid.Column="1" Text="输出点" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <DataGrid Grid.Row="1" Grid.Column="0" ItemsSource="{Binding InputPoints}"/>
            <DataGrid Grid.Row="1" Grid.Column="1" ItemsSource="{Binding OutputPoints}"/>
        </Grid></TabItem>

        <!-- 网络 -->
        <TabItem Header="网络配置"><Grid Margin="16"><StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><TextBlock Text="MQTT Broker:" Width="120" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/><TextBox Text="{Binding NetMqttBroker}" Width="200"/></StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><TextBlock Text="MQTT Port:" Width="120" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/><TextBox Text="{Binding NetMqttPort}" Width="200"/></StackPanel>
            <StackPanel Orientation="Horizontal"><TextBlock Text="MES URL:" Width="120" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/><TextBox Text="{Binding NetMesUrl}" Width="400"/></StackPanel>
        </StackPanel></Grid></TabItem>

        <!-- 用户 -->
        <TabItem Header="用户管理"><Grid Margin="16"><DataGrid ItemsSource="{Binding Users}"/></Grid></TabItem>
    </TabControl>
</UserControl>
